# ─── Orbit Smart Home — Firebase Environment Variables ───────────────────────
#
# Copy this file to .env and fill in your Firebase project values.
# For Netlify: add these same keys in Site Settings → Environment Variables.
#
# Where to find these values:
#   Firebase Console → Project Settings → General → Your apps → Web app
#

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# ─── Firebase Console Setup Checklist ────────────────────────────────────────
#
# 1. Authentication → Sign-in method → Enable "Google"
#    Add your support email when prompted.
#
# 2. Authentication → Settings → Authorised domains → Add:
#    • localhost  (already there)
#    • your-site.netlify.app
#    • any custom domain
#
# 3. Deploy Firestore rules:
#    firebase deploy --only firestore:rules
#
# 4. Deploy RTDB rules:
#    firebase deploy --only database
#
# 5. RTDB → Create database → add this structure manually for each ESP8266:
#    deviceData/
#      ESP8266-XXXXXX/
#        info/
#          relayCount: 4
#          firmwareVersion: "1.0.0"
#          deviceType: "relay"
#          ownerId: ""
#          password: "<SHA-256 hex of device password>"
#        pendingBits: 0
#
# ─── Netlify Deploy ───────────────────────────────────────────────────────────
#
# 1. Connect GitHub repo to Netlify
# 2. Build command: npm run build
# 3. Publish directory: dist
# 4. Add all VITE_FIREBASE_* env vars in Netlify UI
# 5. netlify.toml already handles SPA routing redirects
