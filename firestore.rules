rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: valid Google-authenticated user ───────────────────────────
    function isAuthedUser() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    function isOwner(uid) {
      return isAuthedUser() && request.auth.uid == uid;
    }

    // ─── Users ────────────────────────────────────────────────────────────
    // Only the account holder can read/write their own profile
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ─── Devices ──────────────────────────────────────────────────────────
    match /devices/{deviceId} {
      // Read: authenticated owner of this device
      allow read: if isAuthedUser()
        && resource.data.ownerUid == request.auth.uid;

      // Create: authenticated, must set themselves as owner
      allow create: if isAuthedUser()
        && request.resource.data.ownerUid == request.auth.uid;

      // Update/Delete: authenticated owner only
      allow update, delete: if isAuthedUser()
        && resource.data.ownerUid == request.auth.uid;
    }

    // ─── Rooms ────────────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read: if isAuthedUser()
        && resource.data.ownerUid == request.auth.uid;

      allow create: if isAuthedUser()
        && request.resource.data.ownerUid == request.auth.uid;

      allow update, delete: if isAuthedUser()
        && resource.data.ownerUid == request.auth.uid;
    }

    // ─── Automations ──────────────────────────────────────────────────────
    match /automations/{automationId} {
      allow read: if isAuthedUser()
        && resource.data.ownerUid == request.auth.uid;

      allow create: if isAuthedUser()
        && request.resource.data.ownerUid == request.auth.uid;

      allow update, delete: if isAuthedUser()
        && resource.data.ownerUid == request.auth.uid;
    }

    // ─── Block everything else ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
